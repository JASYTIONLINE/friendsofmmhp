# Node (npm install for scripts only — not required for static browsing)
node_modules/

# OS / editor noise
.DS_Store
Thumbs.db
*.log

# Python
__pycache__/
*.py[cod]
*.pyc

# Data-admin “Save As” Google Calendar exports (folder kept via .gitkeep)
assets/data/csv/export/*.csv

# Local dated copies of master JSON (optional); remove this line to track backups in git
assets/data/json/backups/

# Cursor — ignore local/editor noise; track only .cursor/rules/ for cross-PC sync
.cursor/*
!.cursor/rules/
!.cursor/rules/**

# Local background notes, drafts, and future assets — not part of the public site delivery
private/

# Capstone / course docs kept locally at repo root; not published with the static site repo
/docs/
